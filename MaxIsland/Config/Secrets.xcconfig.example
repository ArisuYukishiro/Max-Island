// Secrets.xcconfig.example
//
// HOW TO USE
// ----------
// 1. Copy this file:  cp Secrets.xcconfig.example Secrets.xcconfig
// 2. Fill in your real values in Secrets.xcconfig.
// 3. Secrets.xcconfig is gitignored — never commit it with real keys.
//
// NOTE: xcconfig treats // as a comment, so URLs must use the _SLASH workaround below.

// Required — do not remove this line
_SLASH = /

// Base URL for the Max Island API
API_BASE_URL = https:$(_SLASH)$(_SLASH)your-api-base-url-here

